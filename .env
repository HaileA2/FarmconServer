NODE_ENV=development
PORT=3000

# PostgreSQL
DB_HOST=localhost
DB_PORT=5432
DB_NAME=Farmconnect
DB_USER=haile
DB_PASSWORD=12345
DB_POOL_MAX=10

# Redis (if not installed locally, leave as-is — server will log a warning but won't crash)
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# JWT secrets (change these to any long random string)
ACCESS_TOKEN_SECRET=farmconnect_access_secret_dev_2025
REFRESH_TOKEN_SECRET=farmconnect_refresh_secret_dev_2025
ACCESS_TOKEN_EXPIRY=15m
REFRESH_TOKEN_EXPIRY=7d

# Bcrypt
BCRYPT_ROUNDS=10

# App
APP_BASE_URL=http://localhost:3000
CORS_ORIGIN=*

# Chapa Payment Gateway
CHAPA_SECRET_KEY=
CHAPA_BASE_URL=https://api.chapa.co/v1

# Telebirr Payment Gateway
TELEBIRR_APP_ID=
TELEBIRR_APP_KEY=
TELEBIRR_SHORT_CODE=
TELEBIRR_PUBLIC_KEY=
